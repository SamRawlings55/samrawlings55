---
layout: base.njk
title: Sam Rawlings
description: Personal site of Sam Rawlings.
permalink: /
---

<p class="intro">
  {{ site.bio }}
</p>

<div class="home-section">
  <div class="section-head">
    <span class="section-label">recent writing</span>
    <span class="section-label"><a href="/writing/">see all →</a></span>
  </div>
  {% for post in collections.posts | limit(3) %}
    <a class="row" href="{{ post.url }}">
      <span class="row-title">{{ post.data.title }}</span>
      <span class="row-meta">{{ post.date | shortDate }}</span>
    </a>
  {% endfor %}
</div>

<div class="home-section">
  <div class="section-head">
    <span class="section-label">recently on the shelf</span>
    <span class="section-label"><a href="/shelf/">see all →</a></span>
  </div>
  {% for item in shelf | limit(3) %}
    <div class="row" data-type="{{ item.type }}" style="display:flex">
      <div class="row-left">
        {% if item.link %}
        <a class="row-title" href="{{ item.link }}" target="_blank">{{ item.title }}{% if item.author %} — {{ item.author }}{% endif %}</a>
        {% else %}
        <span class="row-title">{{ item.title }}{% if item.author %} — {{ item.author }}{% endif %}</span>
        {% endif %}
        {% if item.note %}<span class="row-desc">{{ item.note }}</span>{% endif %}
      </div>
      <div class="row-right">
        <span class="row-meta">{{ item.type }}</span>
        <span class="stars">{{ item.rating | stars }}</span>
      </div>
    </div>
  {% endfor %}
</div>
