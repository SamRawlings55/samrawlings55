<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title != "Sam Rawlings" %} — Sam Rawlings{% endif %}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or 'Sam Rawlings' }}">
  <meta property="og:url" content="https://samrawlings.net{{ page.url }}">
  <meta property="og:type" content="website">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="container">

  <a class="site-name" href="/">Sam Rawlings</a>
  <nav>
    <a href="/" {% if page.url == "/" %}class="active"{% endif %}>home</a>
    <a href="/writing/" {% if "/writing" in page.url %}class="active"{% endif %}>writing</a>
    <a href="/shelf/" {% if "/shelf" in page.url %}class="active"{% endif %}>shelf</a>
    <a href="/photos/" {% if "/photos" in page.url %}class="active"{% endif %}>photos</a>
  </nav>

  {{ content | safe }}

</div>
</body>
</html>
